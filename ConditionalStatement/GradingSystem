#include<stdio.h>
int main()
{
    int m1,m2,m3,m4,m5;
    float per;
    scanf("%d%d%d%d%d",&m1,&m2,&m3,&m4,&m5);
    per=(m1+m2+m3+m4+m5)/5.0;
    printf("Percentage=%.2f\n",per);
    if(per>=90)
    printf("O grade");
    else if(per>=80 && per<90)
    printf("A+ grade");
    else if(per>=70 && per<80)
    printf("A grade");
    else if(per>=60 && per<70)
    printf("B+ grade");
    else
    printf("Fail");
    return 0;
}