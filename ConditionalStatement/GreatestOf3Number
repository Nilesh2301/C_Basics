#include<stdio.h>
int main()
{
    int a,b,c;
    scanf("%d%d%d",&a,&b,&c);
    (a>b)?(a>c)?printf("a is greatest"):printf("c is greatest"):(b>c)?printf("b is greatest"):printf("c is greatest");
    printf("%d is greatest",(a>b)?(a>c)?a:c:(b>c)?b:c);
    
    return 0;
}

