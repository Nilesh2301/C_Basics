#include <stdio.h>

int isPrime(int n) {
    if (n <= 1)
        return 0;

    for (int j = 2; j * j <= n; j++) {
        if (n % j == 0)
            return 0;
    }
    return 1;
}

int main() {
    int n;
    scanf("%d", &n);

    for (int i = 2; i <= n; i++) {
        if (isPrime(i)) {
            printf("%d ", i);
        }
    }

    return 0;
}