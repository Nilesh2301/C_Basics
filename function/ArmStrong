#include <stdio.h>
#include <math.h>

void checkArmstrong(int *n) {
    int temp = *n, c = 0, sum = 0;

    
    while (temp > 0) {
        temp = temp / 10;
        c++;
    }

    temp = *n;

    
    while (temp > 0) {
        int digit = temp % 10;
        sum = sum + pow(digit, c);
        temp = temp / 10;
    }

    if (sum == *n)
        printf("Armstrong number");
    else
        printf("Not an Armstrong number");
}

int main() {
    int n;
    scanf("%d", &n);
    checkArmstrong(&n);   
    return 0;
}



