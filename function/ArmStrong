#include <stdio.h>
#include <math.h>

int main(){
    int n, sum = 0, rem, count = 0;

    scanf("%d", &n);
    int t = n;   // store original number

 
    while(n != 0){
        rem = n % 10;
        n = n / 10;
        count++;
    }

    int temp = t;

    
    while(temp != 0){
        rem = temp % 10;
        sum = sum + (int)pow(rem, count);
        temp = temp / 10;
    }

    printf("Sum = %d\n", sum);

  
    if(sum == t)
        printf("Armstrong number");
    else
        printf("Not an Armstrong number");

    return 0;
}  