#include <stdio.h>

void decimalToOctal(int n);

int main() {
    int n;
    scanf("%d", &n);

    if (n == 0) {
        printf("0");
    } else {
        decimalToOctal(n);
    }

    return 0;
}

void decimalToOctal(int n) {
    if (n == 0)
        return;

    decimalToOctal(n / 8);
    printf("%d", n % 8);
}
