#include<stdio.h>
int main()
{
	int n,rem,sum=0;
	scanf("%d",&n);
	while(n!=0)
	{
		rem=n%10;
		sum=sum+rem;
		n=n/10;
	}
	printf("Sum=%d",sum);
	return 0;
}



//reverse

#include<stdio.h>
int main()
{
	int n,rem,rev=0;
	scanf("%d",&n);
	while(n!=0)
	{
		rem=n%10;
		rev=rev*10+rem;
		n=n/10;
	}
	printf("Reverse=%d",rev);
	return 0;
}

//Palindrome

#include<stdio.h>
int main()
{
	int n,rem,rev=0,t;
	scanf("%d",&n);
	t=n;
	while(n!=0)
	{
		rem=n%10;
		rev=rev*10+rem;
		n=n/10;
	}
	printf("Reverse=%d",rev);
	if(t==rev)
	printf("No. is palindrome");
	else
	printf("No. is not palindrome");
	return 0;
}

