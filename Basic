//Multiplication of first n natural nos(factorial)
#include<stdio.h>
int main()
{
	int n,i;
	long int fact=1;
	scanf("%d",&n);
	for(i=1;i<=n;i++)
	{
		fact=fact*i;
	}
	printf("Factorial=%ld",fact);
}

// count even nos between a particular range
#include<stdio.h>
int main()
{
	int m,n,i,counte=0,counto=0;
	scanf("%d%d",&m,&n);
	for(i=m;i<=n;i++)
	{
		if(i%2==0)
		counte++;
		else
		counto++;
	}
	printf("Count of even no=%d\n",counte);
	printf("Count of odd no=%d\n",counto);
}


//sum of digits of a number

#include<stdio.h>
int main()
{
	int n,rem,sum=0;
	scanf("%d",&n);
	while(n!=0)
	{
		rem=n%10;
		sum=sum+rem;
		n=n/10;
	}
	printf("Sum=%d",sum);
	return 0;
}



//reverse

#include<stdio.h>
int main()
{
	int n,rem,rev=0;
	scanf("%d",&n);
	while(n!=0)
	{
		rem=n%10;
		rev=rev*10+rem;
		n=n/10;
	}
	printf("Reverse=%d",rev);
	return 0;
}

//Palindrome

#include<stdio.h>
int main()
{
	int n,rem,rev=0,t;
	scanf("%d",&n);
	t=n;
	while(n!=0)
	{
		rem=n%10;
		rev=rev*10+rem;
		n=n/10;
	}
	printf("Reverse=%d",rev);
	if(t==rev)
	printf("No. is palindrome");
	else
	printf("No. is not palindrome");
	return 0;
}

