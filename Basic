//Passing array element by element
#include<stdio.h>
void fun(int);
int main()
{
	int i,n;
	scanf("%d",&n);
	int a[n];
	for(i=0;i<n;i++)
	{
		scanf("%d",&a[i]);
		fun(a[i]);
	}
	printf("\n\nprinting in main\n");
	for(i=0;i<n;i++)
	{
		printf("%d ",a[i]);
		
	}
return 0;
}
void fun(int x)
{
	printf("%d ",++x);
}


