//Binary Search
// Condition for binary search is array must be sorted
#include<stdio.h>
int main()
{
 int beg,end, mid, n, key,i;
 printf("enter the size of array");
 scanf("%d",&n);
 int a[n];
 for(i=0;i<n;i++)
 scanf("%d",&a[i]);
 printf("enter key to search");
 scanf("%d",&key);
 beg=0;
 end=n-1;
 while(beg<=end)
 {
 	mid=(beg+end)/2;
     if (a[mid]==key)
	{
		printf("key is found at %d position",mid+1);
		break;
	}
	else if(key>a[mid])
	{
		beg=mid+1;
	}
		else if(key<a[mid])
	{
		end=mid-1;
	}
 }//while ends
 if(beg>end)
 {
 printf("key is not in this array");
}
return 0;
}




