#include <stdio.h>
int main(){
	int a[10],i,n;
	printf("Enter the No. of Elements");
	scanf("%d",&n);
	printf("Enter elements: ");
	for(i=0;i<n;i++){
		scanf("%d",&a[i]);
		
	}
	printf("\n The elements are \n");
	printf("Reverse Elements are");
	for(i=n-1;i>=0;i--){
		printf("\n%d",a[i]);
	}
	
	return 0;
}