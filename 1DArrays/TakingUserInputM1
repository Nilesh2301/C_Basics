#include <stdio.h>
int main(){
	int a[10],i,n;
	printf("Enter the No. of Elements");
	scanf("%d",&n);
	printf("Enter elements: ");
	for(i=0;i<n;i++){
		scanf("%d",&a[i]);
	}
	printf("\n The elements are \n");
	for(i=0;i<n;i++){
		printf("%d %u\n",a[i],&a[i]);
	}
	printf("\n\n%u",sizeof(a));
	return 0;
}