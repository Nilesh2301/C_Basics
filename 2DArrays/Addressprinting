#include <stdio.h>
int main(){
	int a[3][3],i,j;
	for(i=0;i<3;i++){//for lopp for rows
		for(j=0;j<3;j++){//for loop for column
			scanf("%d",&a[i][j]);
		}//end of column
	}//end of rows
printf("element of 2D matrix are \n");
for(i=0;i<3;i++){
	for(j=0;j<3;j++){
		printf("%d %u\t ",a[i][j],&a[i][j]);
	}//end for
printf("\n");
}
return 0;
}