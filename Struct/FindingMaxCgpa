#include <stdio.h>
struct student{
	char name[20];
	int r;
	float cgpa;
}s[3];
int main(){
	int i,n;
	scanf("%d",&n);
	for(i=0;i<n;i++){
		scanf("%s %d %f",s[i].name,&s[i].r,&s[i].cgpa);
	}
	for(i=0;i<n;i++){
		printf("%s\n%d\n%f",s[i].name,s[i].r,s[i].cgpa);
	}
	return 0;
	float max=s[1].cgpa;
	for(i=0;i<n;i++){
		if(max<s[i].cgpa){
			max=s[i].cgpa;
		}else{
			max=s[1].cgpa;
		}
	}
	printf("Max CGPA Is: %f ",max);
}